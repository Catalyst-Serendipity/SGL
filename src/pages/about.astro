---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const title = "Tentang Kami — Sejarah Soto Gareng Lama Banyumas";
const description = "Soto Gareng Lama adalah warung soto legendaris di Banyumas dengan resep warisan turun-temurun. Kenali filosofi, visi, dan sejarah kuliner kami yang telah menjadi bagian budaya Banyumas.";
---

<BaseLayout {title} {description}>
  <slot name="header"><Header /></slot>

  <!-- Page Hero -->
  <section class="bg-[#2C1A0E] py-16 px-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url(\'data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23C9942A' fill-opacity='1'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/svg%3E\');"></div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <span class="text-[#C9942A] text-xs uppercase tracking-[0.3em] font-medium" style="font-family:'Lora',serif;">Warisan Kuliner</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-3 mb-4" style="font-family:'Playfair Display',serif;">Tentang Kami</h1>
      <p class="text-[#E8B84B]/60 text-sm" style="font-family:'Lora',serif; font-style:italic;">Sejarah & Filosofi Soto Gareng Lama</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 py-16">

    <!-- Intro -->
    <div class="text-center mb-14">
      <div class="inline-block p-4 rounded-full bg-[#F5E8D0] mb-6">
        <img src="/logo.png" alt="Logo Soto Gareng Lama" class="w-24 h-24 rounded-full ring-4 ring-[#C9942A]/30" />
      </div>
      <h2 class="text-2xl md:text-3xl font-bold text-[#2C1A0E] mb-4" style="font-family:'Playfair Display',serif;">
        "Soto Bukan Sekadar Makanan,<br>Tapi Warisan Budaya"
      </h2>
      <div class="h-px w-24 mx-auto bg-gradient-to-r from-transparent via-[#C9942A] to-transparent"></div>
    </div>

    <!-- Story -->
    <div class="grid md:grid-cols-5 gap-10 mb-16">
      <div class="md:col-span-3 text-[#5C3317] leading-relaxed" style="font-family:'Lora',serif;">
        <p class="mb-5 text-base">
          <strong class="text-[#2C1A0E]">Soto Gareng Lama</strong> adalah warisan kuliner yang mengusung cita rasa soto otentik khas Jawa Tengah, khususnya Banyumas. Kami telah menjadi bagian dari sejarah kuliner Banyumas, melayani ribuan keluarga dengan resep yang sama — resep yang tak pernah berubah karena memang tak perlu diubah.
        </p>
        <p class="mb-5 text-base">
          Nama "Gareng" bukan sekadar nama. Ia adalah identitas, cerminan karakter khas wong Banyumas — sederhana, jujur, dan hangat. Sementara "Lama" menegaskan bahwa kami adalah yang asli, yang orisinal, penjaga tradisi di tengah arus perubahan.
        </p>
        <p class="text-base">
          Di setiap mangkuk yang kami sajikan, terkandung jam-jam merebus kaldu, pilihan rempah yang teliti, dan kasih sayang yang sama seperti ketika nenek-moyang kami pertama kali memasak soto ini untuk keluarga.
        </p>
      </div>
      <div class="md:col-span-2 flex flex-col gap-4">
        {[
          { icon: '📜', label: 'Resep Turun-Temurun', desc: 'Warisan rasa yang tak lekang waktu' },
          { icon: '🌿', label: 'Bahan Segar Harian', desc: 'Dipilih setiap pagi untuk kesegaran terbaik' },
          { icon: '🏆', label: 'Rating Google 5.0', desc: 'Dipercaya ribuan pelanggan Banyumas' },
          { icon: '📍', label: 'Pusat Kota Banyumas', desc: 'Mudah dijangkau dari mana saja' },
        ].map(item => (
          <div class="flex items-center gap-4 bg-[#FDF6EC] rounded-xl p-4 border border-[#C9942A]/15">
            <span class="text-2xl flex-shrink-0">{item.icon}</span>
            <div>
              <p class="font-bold text-[#2C1A0E] text-sm" style="font-family:'Playfair Display',serif;">{item.label}</p>
              <p class="text-[#6B5B4E] text-xs" style="font-family:'Lora',serif;">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Philosophy & Materials -->
    <div class="bg-[#2C1A0E] rounded-3xl p-10 mb-10 text-center">
      <span class="text-[#C9942A] text-xs uppercase tracking-[0.3em] font-medium" style="font-family:'Lora',serif;">Visi Kami</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white mt-3 mb-4" style="font-family:'Playfair Display',serif;">
        Menjaga Tradisi,<br>Merawat Keaslian
      </h2>
      <div class="h-px w-24 mx-auto bg-gradient-to-r from-transparent via-[#C9942A] to-transparent mb-5"></div>
      <p class="text-[#E8B84B]/60 max-w-lg mx-auto text-sm leading-relaxed" style="font-family:'Lora',serif;">
        Menjaga keaslian resep turun-temurun sambil memberikan pelayanan terbaik kepada setiap pelanggan, sehingga setiap kunjungan menjadi kenangan rasa yang tak terlupakan.
      </p>
    </div>

    <!-- Material -->
    <div class="bg-[#F5E8D0] rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-[#2C1A0E] mb-6 text-center" style="font-family:'Playfair Display',serif;">Bahan-Bahan Pilihan Kami</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { emoji: '🐓', name: 'Ayam Kampung Asli', desc: 'Lebih gurih dan bernutrisi tinggi' },
          { emoji: '🥩', name: 'Daging Sapi Asli', desc: 'Pilihan terbaik untuk kaldu kaya rasa' },
          { emoji: '🫀', name: 'Babat Segar', desc: 'Dibersihkan dengan teliti setiap hari' },
          { emoji: '🌶️', name: 'Sambal Kacang', desc: 'Racikan khas yang memberi cita rasa unik' },
          { emoji: '🌿', name: 'Rempah Pilihan', desc: 'Bumbu rahasia warisan keluarga' },
          { emoji: '🥦', name: 'Sayuran Segar', desc: 'Dipilih segar setiap pagi dari pasar' },
        ].map(item => (
          <div class="flex items-center gap-3 bg-white rounded-xl p-4 border border-[#C9942A]/10">
            <span class="text-2xl flex-shrink-0">{item.emoji}</span>
            <div>
              <p class="font-bold text-[#2C1A0E] text-sm" style="font-family:'Playfair Display',serif;">{item.name}</p>
              <p class="text-[#6B5B4E] text-xs" style="font-family:'Lora',serif;">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-10">
      <a href="/menu" class="inline-flex items-center gap-2 px-8 py-4 bg-[#C9942A] hover:bg-[#E8B84B] text-[#2C1A0E] font-bold rounded-full transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 text-sm" style="font-family:'Lora',serif;">
        Lihat Menu Kami →
      </a>
    </div>
  </main>
</BaseLayout>
