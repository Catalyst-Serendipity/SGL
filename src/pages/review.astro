---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ReviewCard from '../components/ReviewCard.astro';

import {
  sortedReviews,
  REVIEWS_PER_PAGE
} from '../utils/reviews';

const title = "Ulasan Pelanggan — Soto Gareng Lama Banyumas";

const description =
  "Baca ulasan pelanggan Soto Gareng Lama Banyumas. Rating 5.0 di Google. Bergabunglah dan bagikan pengalaman Anda menikmati soto ayam kampung, babat, dan sapi khas Banyumas.";

const initialReviews = sortedReviews.slice(
  0,
  REVIEWS_PER_PAGE
);
---

<BaseLayout {title} {description}>

  <slot name="header">
    <Header />
  </slot>

  <section class="relative overflow-hidden bg-[#2C1A0E] px-6 py-16 text-center">

    <div
      class="absolute inset-0 opacity-5"
      style="background-image:url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23C9942A&quot; fill-opacity=&quot;1&quot;%3E%3Ccircle cx=&quot;30&quot; cy=&quot;30&quot; r=&quot;1&quot;/%3E%3C/g%3E%3C/svg%3E');"
    ></div>

    <div class="relative z-10 mx-auto max-w-2xl">

      <span
        class="text-xs font-medium uppercase tracking-[0.3em] text-[#C9942A]"
        style="font-family:'Lora',serif;"
      >
        Testimoni
      </span>

      <h1
        class="mt-3 mb-4 text-4xl font-bold text-white md:text-5xl"
        style="font-family:'Playfair Display',serif;"
      >
        Ulasan Pelanggan
      </h1>

      <div class="mt-4 flex items-center justify-center gap-3">

        <span class="text-3xl text-[#E8B84B]">
          ★★★★★
        </span>

        <div class="text-left">

          <p class="text-xl font-bold leading-none text-white">
            5.0 / 5.0
          </p>

          <p class="text-xs text-[#E8B84B]/50">
            dari Google Reviews
          </p>

        </div>

      </div>

      <p
        class="mt-4 text-sm text-[#E8B84B]/60"
        style="font-family:'Lora',serif;"
      >
        Menampilkan {initialReviews.length} ulasan pilihan pelanggan
      </p>

    </div>

  </section>

  <main class="mx-auto max-w-4xl px-4 py-16">

    <div
      id="review-container"
      class="mb-8 grid gap-6 md:grid-cols-2"
    >

      {initialReviews.map((review) => (

        <ReviewCard
          review={review}
          variant="light"
        />

      ))}

    </div>

    {
      sortedReviews.length > REVIEWS_PER_PAGE && (

        <div class="mb-14 flex justify-center">

          <button
            id="load-more-button"
            type="button"
            class="inline-flex items-center justify-center rounded-full border border-[#C9942A]/30 bg-[#FDF6EC] px-8 py-4 text-sm font-semibold text-[#5C3317] transition-all duration-300 hover:border-[#C9942A] hover:bg-[#FFF4E3] hover:shadow-lg"
            style="font-family:'Lora',serif;"
            data-reviews={JSON.stringify(sortedReviews)}
            data-current-count={initialReviews.length}
            data-per-page={REVIEWS_PER_PAGE}
          >
            Lihat Lebih Banyak
          </button>

        </div>

      )
    }

    <div class="rounded-3xl bg-[#2C1A0E] p-10 text-center">

      <h2
        class="mb-3 text-2xl font-bold text-white"
        style="font-family:'Playfair Display',serif;"
      >
        Sudah Pernah Makan di Sini?
      </h2>

      <p
        class="mx-auto mb-7 max-w-md text-sm text-[#E8B84B]/60"
        style="font-family:'Lora',serif;"
      >
        Bagikan pengalaman Anda dan bantu pelanggan lain menemukan warisan kuliner Banyumas ini. Review Anda sangat berarti bagi kami!
      </p>

      <div class="flex flex-col justify-center gap-4 sm:flex-row">

        <a
          href="https://g.page/r/CdUqqldLQEVhEAE/review"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-[#C9942A] px-8 py-4 text-sm font-bold text-[#2C1A0E] transition-all duration-300 hover:bg-[#E8B84B] hover:shadow-lg"
          style="font-family:'Lora',serif;"
        >
          ✍️ Tulis Ulasan di Google
        </a>

        <a
          href="https://g.co/kgs/XDApvoR"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-[#C9942A]/40 px-8 py-4 text-sm text-[#E8B84B] transition-all duration-300 hover:border-[#C9942A] hover:bg-[#C9942A]/10"
          style="font-family:'Lora',serif;"
        >
          Lihat Semua di Google
        </a>

      </div>

    </div>

  </main>

  <script>
import { Review } from "../utils/reviews";


    const loadMoreButton =
      document.getElementById('load-more-button');

    if (loadMoreButton instanceof HTMLButtonElement) {

      const container =
        document.getElementById('review-container');

      const reviews = JSON.parse(
        loadMoreButton.dataset.reviews || '[]'
      );

      const perPage = Number(
        loadMoreButton.dataset.perPage || 5
      );

      let currentCount = Number(
        loadMoreButton.dataset.currentCount || 0
      );

      loadMoreButton.addEventListener('click', () => {

        const nextReviews = reviews.slice(
          currentCount,
          currentCount + perPage
        );

        nextReviews.forEach((review: Review) => {

          const article =
            document.createElement('article');

          article.className =
            'rounded-[32px] border border-[#C9942A]/10 bg-[#FDF6EC] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-[#C9942A]/30 hover:shadow-xl';

          const initial =
            review.name.charAt(0).toUpperCase();

          article.innerHTML = `
            <div class="flex items-center gap-4">

              <div class="relative h-12 w-12 shrink-0">

                ${
                  review.avatar
                    ? `
                      <img
                        src="${review.avatar}"
                        alt="Foto profil ${review.name}"
                        class="h-12 w-12 rounded-full object-cover ring-2 ring-[#C9942A]/20"
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                      />
                    `
                    : ''
                }

                <div
                  class="${review.avatar ? 'hidden' : 'flex'} h-12 w-12 items-center justify-center rounded-full bg-[#C9942A] text-sm font-bold text-white"
                  style="font-family:'Playfair Display',serif;"
                >
                  ${initial}
                </div>

              </div>

              <div class="min-w-0">

                <p
                  class="truncate text-sm font-semibold text-[#2C1A0E]"
                  style="font-family:'Lora',serif;"
                >
                  ${review.name}
                </p>

                <div class="text-xs text-[#C9942A]">
                  ${'★'.repeat(review.rating)}
                  ${'☆'.repeat(5 - review.rating)}
                </div>

              </div>

            </div>

            <p
              class="mt-5 text-sm italic leading-relaxed text-[#5C3317]"
              style="font-family:'Lora',serif;"
            >
              ${
                review.comment
                  ? `"${review.comment}"`
                  : '✓ Memberikan rating bintang 5'
              }
            </p>

            ${
              review.date
                ? `
                  <time
                    class="mt-4 block text-xs text-[#8B5E3C]/50"
                    style="font-family:'Lora',serif;"
                  >
                    ${review.date}
                  </time>
                `
                : ''
            }
          `;

          container?.appendChild(article);

        });

        currentCount += perPage;

        if (currentCount >= reviews.length) {

          loadMoreButton.style.display = 'none';

        }

      });

    }

  </script>

</BaseLayout>