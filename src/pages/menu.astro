---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ReviewCard from '../components/ReviewCard.astro';

import menuData from '../content/menu.json';
import deliveryPlatforms from '../content/delivery-platforms';
import { featuredReviews } from '../utils/reviews';

const title = "Menu Soto Gareng Lama Banyumas — Harga & Cara Pesan";
const description = "Menu lengkap Soto Gareng Lama Banyumas: Soto Ayam Kampung, Soto Babat, dan Soto Sapi asli khas Banyumas.";
const whatsAppUrl = "https://wa.me/6282138163056";
---

<BaseLayout {title} {description} canonicalPath="/menu">

  <slot name="header">
    <Header />
  </slot>

  <!-- Hero -->
  <section class="relative min-h-[50vh] overflow-hidden">

    <img
      src="/images/hero-soto.png"
      alt="Semangkuk Soto Gareng Lama Banyumas"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/65"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#2C1A0E] via-black/30 to-black/10"></div>
    <div class="absolute left-[-120px] top-[-120px] h-80 w-80 rounded-full bg-[#C9942A]/10 blur-3xl"></div>
    <div class="absolute bottom-[-160px] right-[-120px] h-96 w-96 rounded-full bg-[#E8B84B]/10 blur-3xl"></div>

    <div class="relative z-10 flex min-h-[50vh] items-center">
      <div class="mx-auto max-w-7xl px-6">
        <div class="max-w-3xl">

          <span
            class="inline-block rounded-full border border-[#E8B84B]/20 bg-[#C9942A]/10 px-5 py-2 text-xs uppercase tracking-[0.35em] text-[#F6D27D]"
            style="font-family:'Lora',serif;">
            Soto Legendaris Khas Banyumas
          </span>

          <h1 class="mt-6 text-4xl font-bold leading-tight text-white md:text-6xl" style="font-family:'Playfair Display',serif;">
            Soto Gareng Lama
          </h1>

          <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/80 md:text-lg" style="font-family:'Lora',serif;">
            Cita rasa autentik warisan keluarga dengan kuah gurih khas Banyumas,
            dimasak setiap hari menggunakan bahan pilihan.
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href="#menu"
              class="flex items-center justify-center rounded-2xl bg-[#C9942A] px-8 py-4 text-sm font-bold text-[#2C1A0E] transition-all duration-300 hover:scale-[1.03] hover:bg-[#EBC46A]"
              style="font-family:'Lora',serif;">
              Lihat Menu
            </a>
            <a href={`${whatsAppUrl}?text=Halo%20Soto%20Gareng%20Lama,%20saya%20ingin%20pesan%20soto.`}
              target="_blank" rel="noopener"
              class="flex items-center justify-center rounded-2xl border border-white/20 bg-white/10 px-8 py-4 text-sm font-semibold text-white transition-all duration-300 hover:bg-white/15"
              style="font-family:'Lora',serif;">
              Pesan via WhatsApp
            </a>
          </div>

        </div>
      </div>
    </div>

  </section>

  <main class="mx-auto max-w-7xl px-4 py-16 pb-12">

    <!-- Info Banner -->
    <div class="relative mb-20 overflow-hidden rounded-[36px] border border-[#EADFD3] bg-[#FFF9F1] p-7 shadow-[0_10px_40px_rgba(0,0,0,0.04)] md:p-8">
      <div class="absolute right-[-50px] top-[-50px] h-40 w-40 rounded-full bg-[#C9942A]/10 blur-3xl"></div>
      <div class="relative z-10 flex items-start gap-5">
        <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-3xl bg-[#C9942A]/10">
          <span class="text-2xl">💡</span>
        </div>
        <div style="font-family:'Lora',serif;">
          <h2 class="text-xl font-bold text-[#2C1A0E]">Pesan Langsung Lebih Hemat</h2>
          <p class="mt-2 text-sm leading-relaxed text-[#6B5B4E] md:text-base">
            Harga di platform online sudah termasuk biaya layanan aplikasi.
            Untuk mendapatkan harga asli warung tanpa tambahan biaya,
            pesan langsung via WhatsApp atau telepon.
          </p>
        </div>
      </div>
    </div>

    <!-- Menu -->
    <section id="menu" class="relative mb-32">

      <div class="absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-[#C9942A]/10 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-80 w-80 rounded-full bg-[#5C3317]/10 blur-3xl"></div>
      </div>

      <div class="mb-16 text-center">
        <span class="inline-block rounded-full border border-[#C9942A]/20 bg-[#FFF9F0] px-5 py-2 text-xs uppercase tracking-[0.3em] text-[#C9942A]" style="font-family:'Lora',serif;">
          Signature Menu
        </span>
        <h2 class="mt-5 text-4xl font-bold text-[#2C1A0E] md:text-5xl" style="font-family:'Playfair Display',serif;">
          Pilihan Soto Favorit
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-[#6B5B4E] md:text-base" style="font-family:'Lora',serif;">
          Soto khas Banyumas dengan kuah gurih autentik, dimasak setiap hari menggunakan bahan pilihan.
        </p>
      </div>

      <div class="grid gap-8 px-1 py-3 md:grid-cols-2 xl:grid-cols-3">
        {menuData.map((item) => {
          const onlinePrice = Math.round((item.price + 1000) * 1.25);
          return (
            <article class="group relative isolate overflow-hidden rounded-[36px] border border-[#EFE3D5] bg-white shadow-[0_10px_40px_rgba(0,0,0,0.05)] transition-transform duration-500 will-change-transform hover:-translate-y-2 hover:shadow-[0_20px_60px_rgba(0,0,0,0.12)]">

              <div class="relative h-[260px] overflow-hidden rounded-t-[36px]">
                <img
                  src={item.picture}
                  alt={`${item.name} Soto Gareng Lama Banyumas`}
                  class="h-full w-full rounded-t-[36px] object-cover transition-transform duration-700 will-change-transform group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 rounded-t-[36px] bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
                <div class="absolute bottom-5 left-5 right-5">
                  <h3 class="text-3xl font-bold text-white" style="font-family:'Playfair Display',serif;">{item.name}</h3>
                </div>
                <div class="absolute right-5 top-5 rounded-full bg-black/50 px-4 py-2 backdrop-blur-md">
                  <span class="text-sm font-semibold text-[#F6D27D]" style="font-family:'Lora',serif;">
                    Rp {item.price.toLocaleString('id-ID')}
                  </span>
                </div>
              </div>

              <div class="p-6">
                <p class="text-sm leading-relaxed text-[#6B5B4E]" style="font-family:'Lora',serif;">{item.description}</p>

                <div class="mt-5 flex items-center justify-between rounded-2xl bg-[#FFF8EF] p-4">
                  <div>
                    <p class="text-xs uppercase tracking-widest text-[#A78762]">Harga Langsung</p>
                    <p class="mt-1 text-2xl font-bold text-[#2C1A0E]">Rp {item.price.toLocaleString('id-ID')}</p>
                  </div>
                  <div class="group/tooltip relative">
                    <button class="flex h-8 w-8 items-center justify-center rounded-full bg-[#F2E5D7] text-sm font-bold text-[#8B5E3C]">?</button>
                    <div class="invisible absolute bottom-12 right-0 z-20 w-56 rounded-2xl bg-[#2C1A0E] p-4 text-xs leading-relaxed text-white opacity-0 shadow-2xl transition-all duration-300 group-hover/tooltip:visible group-hover/tooltip:opacity-100">
                      Harga aplikasi online dapat lebih tinggi karena biaya layanan platform delivery.
                      <div class="mt-3 border-t border-white/10 pt-3">
                        <div class="flex items-center justify-between">
                          <span class="text-white/60">Online:</span>
                          <span class="text-red-300 line-through">Rp {onlinePrice.toLocaleString('id-ID')}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="mt-6 space-y-4">
                  <a
                    href={`${whatsAppUrl}?text=Halo%20Soto%20Gareng%20Lama,%20saya%20ingin%20pesan%20${encodeURIComponent(item.name)}`}
                    target="_blank" rel="noopener"
                    class="flex w-full items-center justify-center rounded-2xl bg-[#2C1A0E] px-6 py-4 text-sm font-bold text-[#F6D27D] transition-all duration-300 hover:scale-[1.015] hover:bg-[#3B2314] hover:shadow-xl"
                    style="font-family:'Lora',serif;">
                    ✦ Pesan via WhatsApp
                  </a>

                  <div class="space-y-3 md:hidden">
                    {deliveryPlatforms.map((platform) => (
                      <a href={platform.url} target="_blank" rel="noopener"
                        class="flex w-full items-center justify-center rounded-2xl border border-[#EFE4D7] bg-[#FAF7F2] px-5 py-4 text-sm font-semibold text-[#2C1A0E] transition-all duration-300 hover:bg-white hover:shadow-lg"
                        style="font-family:'Lora',serif;">
                        Pesan via {platform.name}
                      </a>
                    ))}
                  </div>

                  <div class="hidden grid-cols-3 gap-3 md:grid">
                    {deliveryPlatforms.map((platform) => (
                      <a
                        href={platform.url}
                        target="_blank"
                        rel="noopener"
                        class="group/delivery flex h-[88px] items-center justify-center overflow-hidden rounded-2xl border border-[#EFE4D7] bg-[#FAF7F2] p-4 transition-all duration-300 hover:-translate-y-1 hover:border-[#C9942A]/40 hover:bg-white hover:shadow-xl"
                      >
                        <div class="flex h-full w-full items-center justify-center">
                          <img
                            src={platform.logo}
                            alt={`Logo ${platform.name}`}
                            class:list={[
                              "max-h-[34px] w-auto max-w-[110px] object-contain opacity-90 transition-all duration-300 group-hover/delivery:scale-105 group-hover/delivery:opacity-100",

                              platform.name === "GrabFood" && "max-h-[38px]",
                              platform.name === "GoFood" && "max-h-[30px]",
                              platform.name === "ShopeeFood" && "max-h-[20px] max-w-[72px]"
                            ]}
                            loading="lazy"
                          />
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>

            </article>
          );
        })}
      </div>

    </section>

    <!-- Reviews on menu page -->
    <section>
      <div class="mb-10 text-center">
        <h2 class="text-4xl font-bold text-[#2C1A0E]" style="font-family:'Playfair Display',serif;">Ulasan Pelanggan</h2>
        <div class="mx-auto mt-4 h-px w-28 bg-gradient-to-r from-transparent via-[#C9942A] to-transparent"></div>
      </div>

      <div class="flex snap-x gap-5 overflow-x-auto pb-4 md:grid md:grid-cols-3">
        {featuredReviews.slice(0, 6).map((review) => (
          <div class="min-w-[300px] snap-center md:min-w-0">
            <ReviewCard review={review} variant="light" />
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="https://g.page/r/CdUqqldLQEVhEAE/review" target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 rounded-full border border-[#C9942A]/30 px-7 py-3 text-sm text-[#5C3317] transition-all duration-300 hover:scale-[1.02] hover:border-[#C9942A] hover:text-[#C9942A]"
          style="font-family:'Lora',serif;">
          ✍️ Tambahkan Ulasan di Google
        </a>
      </div>
    </section>

  </main>

  <!-- Sticky mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-gradient-to-t from-[#2C1A0E] to-transparent p-3 md:hidden">
    <a
      href={`${whatsAppUrl}?text=Halo%20Soto%20Gareng%20Lama,%20saya%20ingin%20pesan%20soto.`}
      target="_blank" rel="noopener"
      class="flex w-full items-center justify-center gap-2 rounded-2xl bg-[#C9942A] py-4 text-sm font-bold text-[#2C1A0E] shadow-2xl transition-colors hover:bg-[#E8B84B]"
      style="font-family:'Lora',serif;">
      ✦ Pesan via WhatsApp Sekarang
    </a>
  </div>
  <div class="h-20 md:hidden"></div>

</BaseLayout>