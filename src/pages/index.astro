---
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCard from '../components/ReviewCard.astro';
import menuData from '../content/menu.json';
import { featuredReviews } from '../utils/reviews';

const title = "Soto Gareng Lama Banyumas — Soto Ayam Kampung, Babat & Sapi Asli";
const description = "Soto Gareng Lama adalah warung soto terenak di Banyumas dengan resep turun-temurun. Nikmati Soto Ayam Kampung Asli, Soto Babat, dan Soto Sapi khas Banyumas. Buka setiap hari 09.00–16.00 WIB.";
---

<BaseLayout {title} {description} canonicalPath="/">

  <slot name="header">
    <Header />
  </slot>

  <!-- Hero -->
  <section class="relative flex min-h-[84vh] items-center justify-center overflow-hidden bg-[#2C1A0E]">

    <div
      class="absolute inset-0 scale-105 bg-cover bg-center"
      style="background-image:url('/images/hero-soto-premium.png');"
    ></div>

    <div class="absolute inset-0 bg-[#120A05]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#120A05]/55 via-[#120A05]/30 to-[#120A05]/80"></div>
    <div class="absolute top-20 left-10 h-72 w-72 rounded-full bg-[#C9942A]/10 blur-3xl pointer-events-none"></div>

    <!-- Container -->
    <div class="relative z-10 mx-auto max-w-5xl px-6 pt-16 pb-24 text-center md:pt-24 md:pb-32">

      <div class="fade-up fade-up-delay-1 mb-6">
        <span class="mb-2 block text-sm font-medium uppercase tracking-[0.35em] text-[#E8B84B]/80" style="font-family:'Lora',serif;">
          ✦ Warung Soto Legendaris Banyumas ✦
        </span>
        <div class="mx-auto h-px w-28 bg-gradient-to-r from-transparent via-[#E8B84B] to-transparent"></div>
      </div>

      <h1 class="fade-up fade-up-delay-2 mb-5 text-6xl font-bold leading-[0.95] tracking-[-0.03em] text-white drop-shadow-[0_4px_30px_rgba(0,0,0,0.65)] md:text-8xl" style="font-family:'Playfair Display',serif;">
        Soto Gareng
        <span class="block text-[#E8B84B]">Lama</span>
      </h1>

      <p class="fade-up fade-up-delay-3 mb-3 mt-5 text-lg italic text-[#F6E7C8] md:text-2xl" style="font-family:'Lora',serif;">
        Soto Leluhur dengan Rasa Tak Lekang Waktu
      </p>

      <p class="fade-up fade-up-delay-3 mx-auto mb-12 max-w-2xl text-base leading-relaxed text-[#F6E7C8]/75 md:text-lg" style="font-family:'Lora',serif;">
        Nikmati kehangatan Soto Ayam Kampung Asli, Soto Babat Asli,
        dan Soto Sapi Asli dengan resep turun-temurun khas Banyumas
        yang telah menjaga cita rasa autentik sejak dahulu.
      </p>

      <div class="fade-up fade-up-delay-4 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/menu"
          class="rounded-full bg-[#C9942A] px-9 py-4 text-sm font-semibold uppercase tracking-widest text-[#2C1A0E] shadow-[0_10px_40px_rgba(201,148,42,0.35)] transition-all duration-300 hover:scale-[1.02] hover:bg-[#E8B84B] hover:shadow-[0_15px_50px_rgba(201,148,42,0.5)]"
          style="font-family:'Lora',serif;">
          Lihat Menu
        </a>
        <a href="https://wa.me/6282138163056?text=Halo%20Soto%20Gareng%20Lama,%20saya%20ingin%20pesan%20soto."
          target="_blank" rel="noopener"
          class="rounded-full border border-[#E8B84B]/50 px-8 py-4 text-sm font-semibold uppercase tracking-widest text-[#F6E7C8] backdrop-blur-sm transition-all duration-300 hover:border-[#E8B84B] hover:bg-[#E8B84B]/10"
          style="font-family:'Lora',serif;">
          Pesan via WhatsApp
        </a>
      </div>

      <!-- Card Stats -->
      <div class="fade-up fade-up-delay-5 mt-10 flex flex-wrap justify-center gap-3 md:mt-12 md:gap-6">
        <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-center shadow-[0_10px_35px_rgba(0,0,0,0.18)] backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:bg-black/25 md:px-6 md:py-4">
          <div class="text-base font-bold text-[#E8B84B] md:text-xl" style="font-family:'Playfair Display',serif;">⭐ 5.0</div>
          <div class="mt-0.5 text-[10px] uppercase tracking-widest text-[#F6E7C8]/50 md:mt-1 md:text-xs">Rating Google</div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-center shadow-[0_10px_35px_rgba(0,0,0,0.18)] backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:bg-black/25 md:px-6 md:py-4">
          <div class="text-base font-bold text-[#E8B84B] md:text-xl" style="font-family:'Playfair Display',serif;">Resep Warisan</div>
          <div class="mt-0.5 text-[10px] uppercase tracking-widest text-[#F6E7C8]/50 md:mt-1 md:text-xs">Sejak Dahulu</div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-center shadow-[0_10px_35px_rgba(0,0,0,0.18)] backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:bg-black/25 md:px-6 md:py-4">
          <div class="text-base font-bold text-[#E8B84B] md:text-xl" style="font-family:'Playfair Display',serif;">09–16 WIB</div>
          <div class="mt-0.5 text-[10px] uppercase tracking-widest text-[#F6E7C8]/50 md:mt-1 md:text-xs">Setiap Hari Buka</div>
        </div>
      </div>

    </div>

    <!-- Bottom Gradient Transition -->
    <div class="absolute inset-x-0 bottom-0 h-6 bg-gradient-to-t from-[#F5E8D0] via-[#F5E8D0]/50 to-transparent"></div>
    
    <!-- Bouncing Arrows -->
    <div class="absolute bottom-8 left-0 right-0 z-20 flex justify-center">
      <div class="animate-bounce text-[#E8B84B]/50">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Menu Preview -->
  <section class="section-texture bg-[#F5E8D0] px-6 py-24">
    <div class="mx-auto max-w-5xl">

      <div class="mb-14 text-center">
        <span class="text-xs font-medium uppercase tracking-[0.3em] text-[#C9942A]" style="font-family:'Lora',serif;">Hidangan Andalan</span>
        <h2 class="mt-3 text-3xl font-bold text-[#2C1A0E] md:text-4xl" style="font-family:'Playfair Display',serif;">Menu Soto Kami</h2>
        <div class="divider-emas"><span>✦</span></div>
        <p class="mx-auto max-w-lg text-sm text-[#6B5B4E]" style="font-family:'Lora',serif;">
          Setiap mangkuk adalah karya — kuah bening gurih, rempah pilihan, dan suwiran daging yang sempurna.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {menuData.map(item => (
          <div class="group relative isolate overflow-hidden rounded-[36px] border border-[#EFE3D5] bg-white shadow-[0_10px_40px_rgba(0,0,0,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_60px_rgba(0,0,0,0.12)]">
            <div class="relative h-[220px] overflow-hidden rounded-t-[36px]">
              <img
                src={item.picture}
                alt={`${item.name} - Soto Gareng Lama Banyumas`}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
              <div class="absolute bottom-4 left-5 right-5">
                <h3 class="text-2xl font-bold text-white" style="font-family:'Playfair Display',serif;">{item.name}</h3>
              </div>
              <div class="absolute right-4 top-4 rounded-full bg-black/50 px-4 py-2 backdrop-blur-md">
                <span class="text-sm font-semibold text-[#F6D27D]" style="font-family:'Lora',serif;">
                  Rp {item.price.toLocaleString('id-ID')}
                </span>
              </div>
            </div>
            <div class="p-5">
              <p class="text-sm leading-relaxed text-[#6B5B4E]" style="font-family:'Lora',serif;">{item.description}</p>
              <a
                href={`https://wa.me/6282138163056?text=Halo%20Soto%20Gareng%20Lama,%20saya%20ingin%20pesan%20${encodeURIComponent(item.name)}`}
                target="_blank" rel="noopener"
                class="mt-4 flex w-full items-center justify-center rounded-2xl bg-[#2C1A0E] px-5 py-3.5 text-sm font-bold text-[#F6D27D] transition-all duration-300 hover:bg-[#3B2314] hover:shadow-lg"
                style="font-family:'Lora',serif;">
                ✦ Pesan via WhatsApp
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/menu"
          class="inline-flex items-center gap-2 rounded-full border border-[#C9942A]/40 px-8 py-3.5 text-sm font-semibold text-[#5C3317] transition-all duration-300 hover:border-[#C9942A] hover:text-[#C9942A]"
          style="font-family:'Lora',serif;">
          Lihat Menu Lengkap & Cara Pesan →
        </a>
      </div>

    </div>
  </section>

  <!-- Superiority -->
  <section class="section-texture bg-[#FDF6EC] px-6 py-24">
    <div class="mx-auto max-w-5xl">

      <div class="mb-16 text-center">
        <span class="text-xs font-medium uppercase tracking-[0.3em] text-[#C9942A]" style="font-family:'Lora',serif;">Mengapa Memilih Kami</span>
        <h2 class="mt-3 text-3xl font-bold text-[#2C1A0E] md:text-4xl" style="font-family:'Playfair Display',serif;">Keunggulan Soto Gareng Lama</h2>
        <div class="divider-emas"><span>✦</span></div>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {[
          { icon:'🌿', title:'Bahan Pilihan Segar', desc:'Ayam kampung asli, daging sapi, dan babat segar dipilih setiap hari untuk menjamin kualitas terbaik di setiap mangkuk.' },
          { icon:'📜', title:'Resep Turun-Temurun', desc:'Racikan bumbu rahasia yang diwariskan dari generasi ke generasi, menjaga keaslian cita rasa khas Banyumas yang tak tergantikan.' },
          { icon:'🏠', title:'Suasana Tradisional', desc:'Warung nyaman dengan suasana hangat khas Jawa, pelayanan ramah, dan harga yang bersahabat untuk semua kalangan.' },
        ].map(item => (
          <div class="group rounded-2xl border border-[#C9942A]/10 bg-white p-8 text-center shadow-[0_10px_30px_rgba(0,0,0,0.04)] transition-all duration-500 hover:-translate-y-1 hover:border-[#C9942A]/30 hover:shadow-[0_20px_45px_rgba(0,0,0,0.08)]">
            <div class="mb-5 text-4xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-bold text-[#2C1A0E]" style="font-family:'Playfair Display',serif;">{item.title}</h3>
            <p class="text-sm leading-relaxed text-[#6B5B4E]" style="font-family:'Lora',serif;">{item.desc}</p>
            <div class="mx-auto mt-5 h-px w-0 bg-gradient-to-r from-transparent via-[#C9942A] to-transparent transition-all duration-700 group-hover:w-1/2"></div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- SEO Content -->
  <section class="bg-[#2C1A0E] px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <span class="text-xs font-medium uppercase tracking-[0.3em] text-[#C9942A]" style="font-family:'Lora',serif;">Tentang Kami</span>
      <h2 class="mt-3 mb-6 text-2xl font-bold text-white md:text-3xl" style="font-family:'Playfair Display',serif;">
        Soto Gareng Lama — Soto Terenak di Banyumas
      </h2>
      <div class="mx-auto mb-8 h-px w-24 bg-gradient-to-r from-transparent via-[#C9942A] to-transparent"></div>
      <div class="space-y-4 text-left text-sm leading-relaxed text-[#E8B84B]/60 md:text-base" style="font-family:'Lora',serif;">
        <p>
          <strong class="text-[#E8B84B]">Soto Gareng Lama</strong> adalah
          <strong class="text-[#E8B84B]">warung soto legendaris di Banyumas</strong>
          yang telah menjadi pilihan utama keluarga sejak dahulu. Berlokasi di Jl. Kulon, Sudagaran, Banyumas,
          kami menyajikan <strong class="text-[#E8B84B]">soto ayam kampung asli</strong>,
          <strong class="text-[#E8B84B]">soto babat</strong>, dan
          <strong class="text-[#E8B84B]">soto daging sapi asli</strong>
          dengan resep warisan turun-temurun yang terjaga keasliannya.
        </p>
        <p>
          Bagi Anda yang sedang mencari <strong class="text-[#E8B84B]">soto enak di Banyumas</strong>,
          Soto Gareng Lama adalah destinasi kuliner yang wajib dikunjungi.
          Kuah bening gurih, suwiran daging pilihan, sambal kacang nikmat, dan racikan rempah rahasia
          menjadikan kami rujukan para pecinta kuliner Banyumas, baik warga lokal maupun wisatawan.
        </p>
      </div>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/about"
          class="rounded-full border border-[#C9942A]/40 px-7 py-3 text-sm text-[#E8B84B] transition-all duration-300 hover:border-[#C9942A] hover:bg-[#C9942A]/10"
          style="font-family:'Lora',serif;">
          Baca Cerita Kami →
        </a>
      </div>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-[#FDF6EC] px-6 py-24">
    <div class="mx-auto max-w-5xl">

      <div class="mb-14 text-center">
        <span class="text-xs font-medium uppercase tracking-[0.3em] text-[#C9942A]" style="font-family:'Lora',serif;">Testimoni</span>
        <h2 class="mt-3 text-3xl font-bold text-[#2C1A0E] md:text-4xl" style="font-family:'Playfair Display',serif;">Apa Kata Pelanggan?</h2>
        <div class="mt-4 flex items-center justify-center gap-2">
          <span class="text-2xl text-[#C9942A]">★★★★★</span>
          <span class="font-bold text-[#2C1A0E]">5.0</span>
          <span class="text-sm text-[#6B5B4E]">dari Ulasan Google</span>
        </div>
      </div>

      <div class="mb-10 grid gap-6 md:grid-cols-3">
        {featuredReviews.slice(0, 3).map((review) => (
          <ReviewCard review={review} variant="light" />
        ))}
      </div>

      <div class="flex flex-col justify-center gap-4 text-center sm:flex-row">
        <a href="https://g.page/r/CdUqqldLQEVhEAE/review" target="_blank" rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-[#C9942A]/40 px-6 py-3 text-sm text-[#5C3317] transition-all duration-300 hover:border-[#C9942A] hover:text-[#C9942A]"
          style="font-family:'Lora',serif;">
          ✍️ Tambahkan Ulasan Anda
        </a>
        <a href="/review"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-[#C9942A]/40 px-6 py-3 text-sm text-[#5C3317] transition-all duration-300 hover:border-[#C9942A] hover:text-[#C9942A]"
          style="font-family:'Lora',serif;">
          Lihat Semua Ulasan →
        </a>
      </div>

    </div>
  </section>

  <!-- Location -->
  <section class="bg-[#F5E8D0] px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="grid items-center gap-10 md:grid-cols-2">

        <div>
          <span class="text-xs font-medium uppercase tracking-[0.3em] text-[#C9942A] block mb-3" style="font-family:'Lora',serif;">Kunjungi Kami</span>
          <h2 class="text-3xl font-bold text-[#2C1A0E] mb-5" style="font-family:'Playfair Display',serif;">Temukan Warung Kami</h2>
          <div class="divider-emas w-48 !justify-start !mx-0"><span>✦</span></div>
          <ul class="mt-4 space-y-4 text-[#5C3317]" style="font-family:'Lora',serif;">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-[#C9942A] text-lg flex-shrink-0">📍</span>
              <span>Jl. Kulon, Sudagaran, Banyumas, Jawa Tengah 53192</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-[#C9942A] text-lg flex-shrink-0">⏰</span>
              <span><strong>Buka Setiap Hari</strong> · 09.00 – 16.00 WIB</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-[#C9942A] text-lg flex-shrink-0">📞</span>
              <a href="tel:+6282138163056" class="hover:text-[#C9942A] transition-colors">0821-3816-3056</a>
            </li>
          </ul>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a href="https://maps.google.com/?cid=7004849428266876629" target="_blank" rel="noopener"
              class="rounded-full bg-[#2C1A0E] px-6 py-3 text-center text-sm font-semibold text-[#E8B84B] transition-all duration-300 hover:bg-[#5C3317]"
              style="font-family:'Lora',serif;">
              Buka di Google Maps
            </a>
            <a href="/location"
              class="rounded-full border border-[#C9942A]/40 px-6 py-3 text-center text-sm font-semibold text-[#5C3317] transition-all duration-300 hover:border-[#C9942A] hover:text-[#C9942A]"
              style="font-family:'Lora',serif;">
              Info Lokasi Lengkap
            </a>
          </div>
        </div>

        <div class="h-72 overflow-hidden rounded-2xl border border-[#C9942A]/20 shadow-xl">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3955.1405392151385!2d109.29235471477629!3d-7.512335775424558!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e655b087036fb27%3A0x6145404b57aa2ad5!2sSoto%20Gareng%20Lama!5e0!3m2!1sid!2sid!4v1718466660000"
            width="100%" height="100%"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lokasi Soto Gareng Lama Banyumas"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

  <!-- Sticky mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-gradient-to-t from-[#2C1A0E] to-transparent p-3 md:hidden">
    <a
      href="https://wa.me/6282138163056?text=Halo%20Soto%20Gareng%20Lama,%20saya%20ingin%20pesan%20soto."
      target="_blank" rel="noopener"
      class="flex w-full items-center justify-center gap-2 rounded-2xl bg-[#C9942A] py-4 text-sm font-bold text-[#2C1A0E] shadow-2xl transition-colors hover:bg-[#E8B84B]"
      style="font-family:'Lora',serif;">
      ✦ Pesan via WhatsApp Sekarang
    </a>
  </div>
  <div class="h-20 md:hidden"></div>

  <style>
    .divider-emas { display:flex; align-items:center; gap:1rem; margin:1rem 0; }
    .divider-emas::before, .divider-emas::after { content:''; flex:1; height:1px; background:linear-gradient(to right, transparent, #C9942A, transparent); }
    .divider-emas span { color:#C9942A; font-size:1rem; }
  </style>

</BaseLayout>