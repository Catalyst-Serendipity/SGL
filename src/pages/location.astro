---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const title = "Lokasi Soto Gareng Lama Banyumas — Alamat & Jam Buka";
const description = "Lokasi Soto Gareng Lama: Jl. Kulon, Sudagaran, Banyumas, Jawa Tengah. Buka setiap hari pukul 09.00–16.00 WIB. Hubungi 0821-3816-3056 untuk informasi lebih lanjut.";
---

<BaseLayout {title} {description}>
  <slot name="header"><Header /></slot>

  <!-- Page Hero -->
  <section class="bg-[#2C1A0E] py-16 px-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url(\'data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23C9942A' fill-opacity='1'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/svg%3E\');"></div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <span class="text-[#C9942A] text-xs uppercase tracking-[0.3em] font-medium" style="font-family:'Lora',serif;">Temukan Kami</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-3 mb-4" style="font-family:'Playfair Display',serif;">Lokasi Kami</h1>
      <p class="text-[#E8B84B]/60 text-sm" style="font-family:'Lora',serif; font-style:italic;">Jl. Kulon, Sudagaran, Banyumas, Jawa Tengah</p>
    </div>
  </section>

  <main class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-5 gap-10">

      <!-- Info Sidebar -->
      <div class="md:col-span-2 space-y-5">
        <!-- Address -->
        <div class="bg-[#FDF6EC] rounded-2xl p-6 border border-[#C9942A]/15">
          <h2 class="text-lg font-bold text-[#2C1A0E] mb-4 flex items-center gap-2" style="font-family:'Playfair Display',serif;">
            <span class="text-[#C9942A]">📍</span> Alamat
          </h2>
          <address class="text-[#5C3317] text-sm not-italic leading-relaxed" style="font-family:'Lora',serif;">
            Jl. Kulon, Mruyung, Sudagaran<br>
            Banyumas, Jawa Tengah 53192<br>
            Indonesia
          </address>
          <a href="https://maps.google.com/?cid=7004849428266876629" target="_blank" rel="noopener"
            class="mt-4 flex items-center gap-2 text-xs text-[#C9942A] hover:text-[#8B5E3C] font-semibold transition-colors"
            style="font-family:'Lora',serif;">
            Buka di Google Maps →
          </a>
        </div>

        <!-- Jam Buka -->
        <div class="bg-[#FDF6EC] rounded-2xl p-6 border border-[#C9942A]/15">
          <h2 class="text-lg font-bold text-[#2C1A0E] mb-4 flex items-center gap-2" style="font-family:'Playfair Display',serif;">
            <span class="text-[#C9942A]">⏰</span> Jam Operasional
          </h2>
          <div class="space-y-2 text-sm" style="font-family:'Lora',serif;">
            {['Senin','Selasa','Rabu','Kamis','Jumat','Sabtu','Minggu'].map(hari => (
              <div class="flex justify-between items-center py-1 border-b border-[#C9942A]/10">
                <span class="text-[#5C3317]">{hari}</span>
                <span class="text-[#2C1A0E] font-semibold">09.00 – 16.00 WIB</span>
              </div>
            ))}
          </div>
          <p class="mt-3 text-xs text-[#6B5B4E] italic" style="font-family:'Lora',serif;">*Jam buka dapat berubah di hari libur tertentu</p>
        </div>

        <!-- Contact -->
        <div class="bg-[#2C1A0E] rounded-2xl p-6">
          <h2 class="text-lg font-bold text-[#E8B84B] mb-4 flex items-center gap-2" style="font-family:'Playfair Display',serif;">
            <span>📞</span> Hubungi Kami
          </h2>
          <div class="space-y-3">
            <a href="tel:+6282138163056"
              class="flex items-center gap-3 text-[#E8B84B]/80 hover:text-[#E8B84B] transition-colors text-sm"
              style="font-family:'Lora',serif;">
              📞 0821-3816-3056
            </a>
            <a href="https://wa.me/6282138163056?text=Halo%20Soto%20Gareng%20Lama%2C%20saya%20ingin%20bertanya." target="_blank" rel="noopener"
              class="flex items-center gap-2 w-full py-3 bg-[#C9942A] hover:bg-[#E8B84B] text-[#2C1A0E] font-bold rounded-xl transition-all duration-300 text-sm justify-center"
              style="font-family:'Lora',serif;">
              WhatsApp Kami
            </a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="md:col-span-3 flex flex-col gap-5">
        <div class="rounded-2xl overflow-hidden shadow-xl border border-[#C9942A]/20 flex-1 min-h-[400px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3955.1405392151385!2d109.29235471477629!3d-7.512335775424558!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e655b087036fb27%3A0x6145404b57aa2ad5!2sSoto%20Gareng%20Lama!5e0!3m2!1sid!2sid!4v1718466660000"
            width="100%" height="100%"
            class="min-h-[400px]"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Peta Lokasi Soto Gareng Lama Banyumas"
          ></iframe>
        </div>

        <!-- Directions quick links -->
        <div class="bg-[#F5E8D0] rounded-2xl p-5 border border-[#C9942A]/15">
          <h3 class="font-bold text-[#2C1A0E] mb-3 text-sm" style="font-family:'Playfair Display',serif;">Petunjuk Arah</h3>
          <div class="grid sm:grid-cols-3 gap-3">
            <a href="https://maps.google.com/?saddr=My+Location&daddr=Soto+Gareng+Lama,Sudagaran,Banyumas" target="_blank" rel="noopener"
              class="text-center py-2.5 px-3 bg-white rounded-xl border border-[#C9942A]/20 hover:border-[#C9942A] text-[#5C3317] hover:text-[#C9942A] text-xs font-semibold transition-all duration-200"
              style="font-family:'Lora',serif;">
              🚗 Dari Sini
            </a>
            <a href="https://maps.google.com/?cid=7004849428266876629" target="_blank" rel="noopener"
              class="text-center py-2.5 px-3 bg-white rounded-xl border border-[#C9942A]/20 hover:border-[#C9942A] text-[#5C3317] hover:text-[#C9942A] text-xs font-semibold transition-all duration-200"
              style="font-family:'Lora',serif;">
              📍 Lihat di Maps
            </a>
            <a href="https://g.co/kgs/XDApvoR" target="_blank" rel="noopener"
              class="text-center py-2.5 px-3 bg-white rounded-xl border border-[#C9942A]/20 hover:border-[#C9942A] text-[#5C3317] hover:text-[#C9942A] text-xs font-semibold transition-all duration-200"
              style="font-family:'Lora',serif;">
              ⭐ Ulasan Google
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
